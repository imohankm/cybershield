{
  "manifest_version": 3,
  "name": "AI CyberShield",
  "version": "1.0",
  "description": "Protects you from phishing sites using AI.",
  "permissions": [
    "webNavigation",
    "storage",
    "activeTab",
    "scripting",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "css": [
        "content.css"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "AI CyberShield"
  }
}