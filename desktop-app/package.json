{
  "name": "ai-cybershield",
  "version": "1.0.0",
  "description": "AI CyberShield Control Center",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder build --win"
  },
  "build": {
    "appId": "com.aicybershield.master",
    "productName": "CyberShield Master Suite",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CyberShield",
      "runAfterFinish": true
    },
    "files": [
      "**/*",
      "!dist"
    ]
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  }
}
